# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-use-openssl-rand-base64-32-to-generate

# GitHub OAuth
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# Google OAuth
GOOGLE_ID=your-google-oauth-app-id
GOOGLE_SECRET=your-google-oauth-app-secret

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/mycoo_db

# Lemlist Integration (Phase 2)
LEMLIST_API_KEY=your-lemlist-api-key-here

# Claude Webhook (Phase 3)
CLAUDE_WEBHOOK_SECRET=your-claude-webhook-secret
CLAUDE_WEBHOOK_URL=https://your-claude-code-url
